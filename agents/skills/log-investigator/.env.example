# ========================================
# Log Investigator - Environment Configuration
# ========================================
#
# Instructions:
# 1. Copy this file to .env and fill in actual values
# 2. .env file contains sensitive information, DO NOT commit to git
#
# Windows: copy .env.example .env
# Linux/Mac: cp .env.example .env
# ========================================

# ----------------------------------------
# Development Environment Elasticsearch
# ----------------------------------------
ES_DEV_URL=http://your-elasticsearch-dev:9200
ES_DEV_USERNAME=
ES_DEV_PASSWORD=

# Or use API Key authentication (choose one)
# ES_DEV_API_KEY=

# Kibana URL (optional, for query links)
KIBANA_DEV_URL=http://your-kibana-dev:5601

# ----------------------------------------
# Test Environment Elasticsearch
# ----------------------------------------
ES_TEST_URL=http://your-elasticsearch-test:9200
ES_TEST_USERNAME=
ES_TEST_PASSWORD=

# Or use API Key authentication (choose one)
# ES_TEST_API_KEY=

# Kibana URL (optional, for query links)
KIBANA_TEST_URL=http://your-kibana-test:5601

# ----------------------------------------
# UAT Environment Elasticsearch
# ----------------------------------------
ES_UAT_URL=http://your-elasticsearch-uat:9200
ES_UAT_USERNAME=
ES_UAT_PASSWORD=

# Or use API Key authentication (choose one)
# ES_UAT_API_KEY=

# Kibana URL (optional, for query links)
KIBANA_UAT_URL=http://your-kibana-uat:5601

# ----------------------------------------
# Pre-production Environment Elasticsearch
# ----------------------------------------
ES_PRE_URL=http://your-elasticsearch-pre:9200
ES_PRE_USERNAME=
ES_PRE_PASSWORD=

# Or use API Key authentication (choose one)
# ES_PRE_API_KEY=

# Kibana URL (optional, for query links)
KIBANA_PRE_URL=http://your-kibana-pre:5601

# ----------------------------------------
# Production Environment Elasticsearch
# ----------------------------------------
ES_PROD_URL=http://your-elasticsearch-prod:9200
ES_PROD_USERNAME=
ES_PROD_PASSWORD=

# Or use API Key authentication (choose one)
# ES_PROD_API_KEY=

# Kibana URL (optional)
KIBANA_PROD_URL=http://your-kibana-prod:5601

# ----------------------------------------
# Optional Configuration
# ----------------------------------------
# Query timeout in seconds
ES_QUERY_TIMEOUT=30

# Max result count
ES_MAX_SIZE=500
