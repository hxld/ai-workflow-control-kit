{
  "version": "2.0",
  "description": "Log Investigator Configuration (non-sensitive)",

  "environments": {
    "test": {
      "name": "Test Environment",
      "envPrefix": "ES_TEST"
    },
    "prod": {
      "name": "Production Environment",
      "envPrefix": "ES_PROD",
      "confirmBeforeQuery": true
    }
  },

  "globalSettings": {
    "defaultEnvironment": "test",
    "defaultTimeRange": "now-7d",
    "defaultSize": 100,
    "maxSize": 500,
    "queryTimeout": 30,
    "retryCount": 3,
    "debugMode": false
  },

  "logSettings": {
    "timestampField": "@timestamp",
    "messageFields": ["message", "log", "msg", "content", "stacktrace"],
    "levelField": "level",
    "levelMapping": {
      "error": ["ERROR", "ERR", "SEVERE", "FATAL"],
      "warn": ["WARN", "WARNING"],
      "info": ["INFO", "INFORMATION"],
      "debug": ["DEBUG", "TRACE"]
    },
    "traceIdFields": ["traceId", "trace_id", "requestId", "request_id", "spanId"]
  },

  "keywords": {
    "npe": ["NullPointerException", "null pointer"],
    "timeout": ["timeout", "TimeoutException", "SocketTimeoutException"],
    "connection": ["Connection refused", "ConnectException", "SocketException"],
    "sql": ["SQLException", "DataAccessException", "DatabaseException"],
    "param": ["IllegalArgumentException", "参数异常", "invalid parameter"],
    "auth": ["AccessDeniedException", "PermissionDenied", "Unauthorized"]
  }
}
