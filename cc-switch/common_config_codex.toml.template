disable_response_storage = true
model_reasoning_effort = "xhigh"
model_verbosity = "high"
web_search = "live"

[windows]
sandbox = "elevated"

[tui]
notification_condition = "always"

[notice]
fast_default_opt_out = true
hide_full_access_warning = true

[features]
hooks = true

[[hooks.UserPromptSubmit]]
[[hooks.UserPromptSubmit.hooks]]
type = "command"
command = "node <CODEX_HOME_SLASH>/hooks/scripts/skill-tracker.js codex_user_prompt_submit"
timeout = 10

[[hooks.Stop]]
[[hooks.Stop.hooks]]
type = "command"
command = "node <USERPROFILE_SLASH>/.agents/hooks/skill-execution-receipt.js"
timeout = 10

[[hooks.Stop]]
[[hooks.Stop.hooks]]
type = "command"
command = "node <CODEX_HOME_SLASH>/hooks/scripts/skill-tracker.js codex_stop"
timeout = 10

[[hooks.SessionStart]]
matcher = "startup|resume"

[[hooks.SessionStart.hooks]]
type = "command"
command = "node <USERPROFILE_SLASH>/.agents/hooks/workflow-sync-state.js"
timeout = 10
